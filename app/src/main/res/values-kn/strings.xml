    <!-- Onboarding -->
    <string name="onboarding_title_1">ಪರಂಪರಾಗತ ಕಲೆಯನ್ನು ಅನ್ವೇಷಿಸಿ</string>
    <string name="onboarding_desc_1">ಭಾರತೀಯ ಕುಶಲಕರ್ಮಿಗಳ ತಲೆಮಾರುಗಳಿಂದ ಬಂದ ಅತ್ಯುತ್ತಮ ಕಲ್ಲು ಮತ್ತು ಮರದ ಕರಕುಶಲ ಕಲೆಯನ್ನು ಅನ್ವೇಷಿಸಿ.</string>
    <string name="onboarding_title_2">ಶಿಲ್ಪಿಗಳೊಂದಿಗೆ ಸಂಪರ್ಕಿಸಿ</string>
    <string name="onboarding_desc_2">ಮಾಸ್ಟರ್ ಕುಶಲಕರ್ಮಿಗಳೊಂದಿಗೆ ನೇರವಾಗಿ ಸಂಪರ್ಕಿಸಿ, ವಿಶೇಷ ತುಣುಕುಗಳನ್ನು ಆದೇಶಿಸಿ.</string>
    <string name="onboarding_title_3">ಪರಂಪರೆಯನ್ನು ಸಂರಕ್ಷಿಸಿ</string>
    <string name="onboarding_desc_3">ಪ್ರತಿ ಕೃತಿಯು ಒಂದು ಕಥೆಯನ್ನು ಹೇಳುತ್ತದೆ. ಭಾರತದ ಶ್ರೀಮಂತ ಶಿಲ್ಪಕಲಾ ಪರಂಪರೆಯನ್ನು ಸಂರಕ್ಷಿಸಲು ಸಹಾಯ ಮಾಡಿ.</string>
